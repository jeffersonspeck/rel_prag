@prefix : <https://example.org/theseus#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:TheseusOntology a owl:Ontology ;
    rdfs:label "Ship of Theseus base ontology"@en ;
    rdfs:comment "Simplified ontology representing only the stable structure S(I_ship)."@en .

:TheseusShip a :Ship ;
    rdfs:label "Ship of Theseus"@en ;
    rdfs:comment "Material instance with stable ontological structure used as a base for external pragmatic interpretations."@en ;
    :hasElement :p_estrutura,
        :p_flutuar,
        :p_material,
        :p_origem,
        :p_papel_monumento,
        :p_valor_historico .

:elementValue a owl:DatatypeProperty ;
    rdfs:label "element value"@en ;
    rdfs:domain :OntologicalElement ;
    rdfs:range xsd:decimal .

:hasElement a owl:ObjectProperty ;
    rdfs:label "has element"@en ;
    rdfs:domain :OntologicalInstance ;
    rdfs:range :OntologicalElement .

:MaterialEntity a owl:Class ;
    rdfs:label "Material entity"@en ;
    rdfs:comment "Simplified class compatible with reading as a material entity/independent continuant."@en ;
    rdfs:subClassOf :OntologicalInstance .

:Role a owl:Class ;
    rdfs:label "Role"@en ;
    rdfs:comment "Condition or function contextually attributed to an entity without changing its ontological base."@en ;
    rdfs:subClassOf :OntologicalElement .

:Ship a owl:Class ;
    rdfs:label "Ship"@en ;
    rdfs:subClassOf :MaterialEntity .

:p_estrutura a :OntologicalElement ;
    rdfs:label "Structural organization"@en ;
    rdfs:comment "Aspect related to the ship's formal configuration and organization."@en ;
    :elementValue 1.0 .

:p_flutuar a :OntologicalElement ;
    rdfs:label "Disposition to float and navigate"@en ;
    rdfs:comment "Realizable disposition associated with floating and navigation capability."@en ;
    :elementValue 1.0 .

:p_material a :OntologicalElement ;
    rdfs:label "Material composition"@en ;
    rdfs:comment "Aspect related to the physical parts and material substrate of the ship."@en ;
    :elementValue 1.0 .

:p_origem a :OntologicalElement ;
    rdfs:label "Origin and provenance"@en ;
    rdfs:comment "Aspect related to the entity's origin, provenance, and historical continuity."@en ;
    :elementValue 1.0 .

:p_papel_monumento a :Role ;
    rdfs:label "Monument role"@en ;
    rdfs:comment "Role contextually attributed to the ship in historical preservation practices."@en ;
    :elementValue 1.0 .

:p_valor_historico a :OntologicalElement ;
    rdfs:label "Historical value"@en ;
    rdfs:comment "Aspect related to the entity's historical, symbolic, and memorial relevance."@en ;
    :elementValue 1.0 .

:OntologicalInstance a owl:Class ;
    rdfs:label "Ontological instance"@en .

:OntologicalElement a owl:Class ;
    rdfs:label "Ontologically grounded element"@en ;
    rdfs:comment "Descriptive component of the instance, such as quality, disposition, function, historical origin, or contextual role."@en .

