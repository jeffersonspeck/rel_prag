@prefix : <https://example.org/theseus#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:TheseusOntology a owl:Ontology ;
    rdfs:label "Ontologia-base do Navio de Teseu"@pt ;
    rdfs:comment "Ontologia simplificada para representar apenas a estrutura estável S(I_navio)."@pt .

:TheseusShip a :Ship ;
    rdfs:label "Navio de Teseu"@pt ;
    rdfs:comment "Instância material com estrutura ontológica estável usada como base para interpretações pragmáticas externas."@pt ;
    :hasElement :p_estrutura,
        :p_flutuar,
        :p_material,
        :p_origem,
        :p_papel_monumento,
        :p_valor_historico .

:elementValue a owl:DatatypeProperty ;
    rdfs:label "valor do elemento"@pt ;
    rdfs:domain :OntologicalElement ;
    rdfs:range xsd:decimal .

:hasElement a owl:ObjectProperty ;
    rdfs:label "tem elemento"@pt ;
    rdfs:domain :OntologicalInstance ;
    rdfs:range :OntologicalElement .

:MaterialEntity a owl:Class ;
    rdfs:label "Entidade material"@pt ;
    rdfs:comment "Classe simplificada compatível com a leitura de entidade material/continuante independente."@pt ;
    rdfs:subClassOf :OntologicalInstance .

:Role a owl:Class ;
    rdfs:label "Papel"@pt ;
    rdfs:comment "Condição ou função contextualmente atribuída a uma entidade sem alterar sua base ontológica."@pt ;
    rdfs:subClassOf :OntologicalElement .

:Ship a owl:Class ;
    rdfs:label "Navio"@pt ;
    rdfs:subClassOf :MaterialEntity .

:p_estrutura a :OntologicalElement ;
    rdfs:label "Organização estrutural"@pt ;
    rdfs:comment "Aspecto relativo à configuração formal e organização do navio."@pt ;
    :elementValue 1.0 .

:p_flutuar a :OntologicalElement ;
    rdfs:label "Disposição para flutuar e navegar"@pt ;
    rdfs:comment "Disposição realizável associada à capacidade de flutuação e navegação."@pt ;
    :elementValue 1.0 .

:p_material a :OntologicalElement ;
    rdfs:label "Composição material"@pt ;
    rdfs:comment "Aspecto relativo às partes físicas e ao substrato material do navio."@pt ;
    :elementValue 1.0 .

:p_origem a :OntologicalElement ;
    rdfs:label "Origem e procedência"@pt ;
    rdfs:comment "Aspecto relativo à origem, procedência e continuidade histórica da entidade."@pt ;
    :elementValue 1.0 .

:p_papel_monumento a :Role ;
    rdfs:label "Papel de monumento"@pt ;
    rdfs:comment "Papel contextualmente atribuído ao navio em práticas de preservação histórica."@pt ;
    :elementValue 1.0 .

:p_valor_historico a :OntologicalElement ;
    rdfs:label "Valor histórico"@pt ;
    rdfs:comment "Aspecto relativo à relevância histórica, simbólica e memorial da entidade."@pt ;
    :elementValue 1.0 .

:OntologicalInstance a owl:Class ;
    rdfs:label "Instância ontológica"@pt .

:OntologicalElement a owl:Class ;
    rdfs:label "Elemento ontologicamente ancorado"@pt ;
    rdfs:comment "Componente descritivo da instância, como qualidade, disposição, função, origem histórica ou papel contextual."@pt .

